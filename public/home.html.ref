.header-select-dropdown select {
    font-size: 18px;
    font-family: 'Oswald';
    text-transform: uppercase;
    background: #9F3238;
    color: #fff;
    border: 0;
    outline: 0;
    border-radius: 0;
    padding: 8px 28px 8px 8px;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    background-image: url(/assets-f/img/49049409785b3f.png);
    background-repeat: no-repeat;
    background-position: center right;
    height: auto;
    cursor: pointer;
    max-width: 150px;
    text-overflow: ellipsis;
    white-space: nowrap;
    background-size: 22px;
    line-height: 1;
}

.header-select-dropdown select:focus {
    border: 0;
}

@media(min-width:767px) {
    .page-template-page-newsroom #project-header .project-title h1 a {
        position: relative;
    }

    .page-template-page-newsroom #project-header .project-title h1 a::after {
        content: "";
        background: #fff;
        width: 100%;
        height: 3px;
        display: block;
        margin-top: auto;
        max-width: 200px;
        position: absolute;
        bottom: 0;
    }
}

@media(max-width:1024px) {
    .page-template-default {
        padding-top: 84px;
    }

    .hero-slider-wrapper.without-shape+#project-header .project-contact {
        padding-right: 106px;
        display: flex;
        width: 100%;
        align-items: center;
    }

    .hero-slider-wrapper.without-shape+#project-header .project-contact .contact-left {
        float: none;
        text-align: left;
    }
}

@media(max-width:767px) {
    .hero-slider-wrapper.without-shape .slide {
        padding-top: 34%;
    }

    .hero-slider-wrapper.without-shape ul.slick-dots {
        left: 20px;
        bottom: 10px !important;
    }

    .hero-slider-wrapper.without-shape ul.slick-dots button {
        width: 18px !important;
        height: 18px !important;
    }


    .hero-slider-wrapper.without-shape+div#project-header::before {
        width: 0px !important;
    }

    #site-header+#project-header {
        min-height: 90px;
    }
}

