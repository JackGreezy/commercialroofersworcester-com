    padding-top: 30%;
    height: auto !important;
}

.post-type-archive #project-header .project-title h1 {
    display: flex;
}

.post-type-archive #project-header .project-title ul {
    list-style: none;
    padding: 0;
    margin: 0;
}

.post-type-archive #project-header .project-title ul li {
    padding: 0;
    left: auto;
    list-style: none;
}

.post-type-archive #project-header .project-title ul .sub-menu {
    display: flex;
}

.post-type-archive #project-header .project-title ul .sub-menu li a {
    line-height: 1;
    padding-right: 12px;
    position: relative;
    margin-right: 12px;
}

.post-type-archive #project-header .project-title ul .sub-menu li a::after {
    content: "";
    display: inline-block;
    width: 1px;
    background: #fff;
    height: 20px;
    position: absolute;
    right: 0;
    bottom: 4px;
}

.post-type-archive #project-header .project-title ul.newsroom-menu {
    padding-left: 40px !important;
    overflow: visible;
}

.post-type-archive #project-header .project-title ul .sub-menu li:last-child a {
    padding-right: 0px;

    line-height: 1;
    margin-right: 0;
}

.post-type-archive #project-header .project-title ul .sub-menu li:last-child a::after {
    display: none;
}

.post-type-archive #project-header .project-title ul .sub-menu li.current-menu-item a {
    font-size: 30px !important;
}

.post-type-archive #project-header .project-title ul .sub-menu {
    overflow: visible;
}

.post-type-archive #project-header .project-title ul .sub-menu li a {
    font-size: 20px;
    color: #fff;
}

.post-type-archive #project-header .project-title {
    width: 70%;
}

.post-type-archive #project-header .project-contact {
    padding-right: 0 !important;
    margin: 0;
    width: 30%;
    margin-right: 0;
    margin-left: auto;
}

.post-type-archive #project-header .project-title h1::after {
    display: none;
}

.post-type-archive #project-header .project-title ul .sub-menu li {
    padding-right: 0px;
}

.post-type-archive #project-header .project-title ul .sub-menu li:first-child a {
    padding-left: 25px;

}

.post-type-archive #project-header .project-title ul .sub-menu li.current-menu-item a {
    top: 2px;
    font-weight: 400;
}

.post-type-archive #project-header .project-title ul .sub-menu li a:hover,

.post-type-archive #project-header .project-title ul .sub-menu li a:focus {
    border-bottom: 0;
}

.header-select-dropdown li {
    list-style: none;
}

.post-type-archive #project-header .project-title ul .sub-menu li:first-child a::before {
    background: #9F3238;
    width: 10px;
    height: 28px;
    content: "";
    position: absolute;
    left: 0;
    top: calc(50% - -1px);
    transform: translateY(-50%);
}

.post-type-archive #project-header .project-title ul .sub-menu li.current-menu-item a::after {
    bottom: 9px !important;
}

.post-type-archive #project-header .project-title ul .sub-menu li.current-menu-item::before {
    content: "";
    position: absolute;
    width: 40%;
    background: #fff;
    height: 1px;
    bottom: -40px;

}

.post-type-archive #project-header .project-title ul .sub-menu li:first-child.current-menu-item::before {
    left: 28px;
}

.blog-item .col-md-3 img {
    border-left: 15px solid #9F3238;
}

.post-type-archive a.moretag {
    display: block;
    margin-top: 10px;
    max-width: max-content;
    border: 0;
    text-transform: uppercase;
    font-family: 'Oswald' !important;
}

.post-type-archive .blog-item {
    margin-bottom: 40px;
}

.post-type-archive .posted a {
    text-transform: uppercase;
    font-family: 'Oswald' !important;
}

.post-type-archive select.navToSelect {
    display: none;
}

.post-type-archive .content-wrap.container-fluid article {
    padding: 0;
}

@media(max-width:1300px) {
    .post-type-archive #project-header .project-title ul .sub-menu li a {
        padding-right: 10px;
        margin-right: 10px;
        font-size: 18px;
    }

    .post-type-archive #project-header .project-title ul.newsroom-menu {
        padding-left: 20px !important;
    }
}

@media(max-width:1200px) {
