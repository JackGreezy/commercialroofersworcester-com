.single-in_the_news nav#blog-navigation #older-articles a,
.single-blog_entries nav#blog-navigation #older-articles a,
.single-news_releases nav#blog-navigation #older-articles a {
    background: #9e2432 !important;
    color: #fff;
    padding: 7px 10px 7px 44px;
    position: relative;
    text-transform: uppercase;
    font-family: 'Oswald' !important;
    letter-spacing: 2px;
    border: 0;
}

.single-in_the_news nav#blog-navigation #older-articles a::after,
.single-blog_entries nav#blog-navigation #older-articles a::after,
.single-news_releases nav#blog-navigation #older-articles a::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 4px !important;
    width: 30px;
    height: 30px;
    background: #fff;
    z-index: 1;
    display: block;
    transform: translateY(-50%);
}

.single-in_the_news nav#blog-navigation #older-articles a::before,
.single-blog_entries nav#blog-navigation #older-articles a::before,
.single-news_releases nav#blog-navigation #older-articles a::before {
    content: "";
    width: 16px;
    height: 16px;
    position: absolute;
    border-left: 2px solid #9e2432;
    border-bottom: 2px solid #9e2432;
    left: 8px;
    z-index: 2;
    transform: rotate(45deg) translateY(-50%);
    transform-origin: center;
    top: calc(50% - 3px);
}

.single-in_the_news nav#blog-navigation #newer-articles a,
.single-blog_entries nav#blog-navigation #newer-articles a,
.single-news_releases nav#blog-navigation #newer-articles a {
    background: #9e2432 !important;
    color: #fff;
    padding: 7px 44px 7px 10px;
    position: relative;
    text-transform: uppercase;
    font-family: 'Oswald' !important;
    letter-spacing: 2px;
    border: 0;
}

.single-in_the_news nav#blog-navigation #newer-articles a::after,
.single-blog_entries nav#blog-navigation #newer-articles a::after,
.single-news_releases nav#blog-navigation #newer-articles a::after {
    content: "";
    position: absolute;
    top: 50%;
    right: 4px !important;
    width: 30px;
    height: 30px;
    background: #fff;
    z-index: 1;
    display: block;
    transform: translateY(-50%);
}

.single-in_the_news nav#blog-navigation #newer-articles a::before,
.single-blog_entries nav#blog-navigation #newer-articles a::before,
.single-news_releases nav#blog-navigation #newer-articles a::before {
    content: "";
    width: 16px;
    height: 16px;
    position: absolute;
    border-right: 2px solid #9e2432;
    border-top: 2px solid #9e2432;
    right: 20px;
    z-index: 2;
    transform: rotate(45deg) translateY(-50%);
    transform-origin: center;
    top: calc(50% - 3px);
}


