    .post-type-archive select.navToSelect {
        display: inline-block;
        font-size: 18px;
        font-family: 'Oswald';
        text-transform: uppercase;
        background: #9F3238;
        color: #fff;
        border: 0;
        outline: 0;
        border-radius: 0;
        padding: 10px 40px 10px 15px;
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
        background-image: url(/assets-f/img/49049409785b3f.png);
        background-repeat: no-repeat;
        background-position: center right;
        height: auto;
        min-width: inherit;
        cursor: pointer;
        background-size: 28px;
        line-height: 1;
    }

    .post-type-archive .content-wrap.container-fluid article {
        padding: 0px 15px;
