@media(max-width:1024px) {

    #content-wrapper .project-contact.mobile {
        background: #0c2340;
    }

    #content-wrapper .project-contact.mobile {
        float: none;
        padding-left: 0;
        margin-bottom: 0;
        display: flex;
        flex-wrap: wrap;
        padding: 10px 0;
        margin-top: 15px;
    }

    #content-wrapper .project-contact.mobile .contact-right {
        position: relative;
        top: auto;
        left: auto;
        width: 90px;
    }

    #content-wrapper .project-contact.mobile .contact-left {
        display: block;
        float: none;
        margin-left: 0;
        z-index: 1;
        position: relative;
        margin-top: 0;
        width: calc(100% - 90px);
    }

    #content-wrapper .project-contact.mobile .contact-right .headshot {
        width: 100%;
        height: 100%;
        position: relative;
        z-index: 1;
        border-radius: 0;

        border-right: 15px solid #9F3238;
    }

    #content-wrapper .project-contact.mobile::after {
        content: "";
        position: absolute;
        top: 0;
        left: 50%;
        width: 100vw;
        height: 100%;
        background: #0c2340;
        transform: translateX(-50%);
        z-index: 0;
    }

    #content-wrapper .project-contact.mobile h3 {
        font-family: 'Oswald' !important;
        color: #fff;
        font-size: 1.25rem;
    }

    #content-wrapper .project-contact.mobile .leader-name {
        color: #fff;
        margin: 3x 0 2px;
        font-family: 'oswald';
        font-size: 16px;
    }

    #content-wrapper .project-contact.mobile .designation {
        color: #fff;
        font-family: 'oswald';
        margin: 0 0 2px;
    }

    #content-wrapper .project-contact.mobile .designation+a span {
        margin: 2px 0 0px;
        color: #fff !important;
        font-family: 'oswald';
    }

    .page-template-page-market-landing {
        padding-top: 84px;
    }

    .page-template-page-market-landing #project-header,
    div#interior-hero+#project-header {
        min-height: 90px;
        align-content
    }

    #project-header .project-title-wrap {
        padding: 15px 0 15px 16px;
    }

    .hero-slider .icon-cursor-right.slick-arrow {
        right: 0px !important;
    }

    .hero-slider .icon-cursor-right.slick-arrow::before {
        width: 30px !important;
        height: 30px !important;
    }

    .hero-slider .icon-cursor-left.slick-arrow {
        left: 10px !important;
    }

    .hero-slider .icon-cursor-left.slick-arrow::before {
        width: 30px !important;
        height: 30px !important;
    }
}

@media(max-width:767px) {
    .slider-bottom-shape {
        display: none;
    }

    .hero-slider-wrapper {
        padding-bottom: 0% !important;
    }

    .hero-slider-wrapper .slider-bottom-shape-mobile {
        display: block !important;
        position: absolute;
        bottom: 0;
        left: 0;
        z-index: 1;
        top: auto;
        width: 100%;
    }

    .hero-slider-wrapper .slider-bottom-shape-mobile img {
        display: block;
        width: 100%;
        max-width: 100%;
    }

    .hero-slider-wrapper+#content-wrapper {
        margin-top: 0 !important;
    }

    .hero-slider-wrapper .slider-caption-wrapper {
        display: none !important;
    }

    .hero-slider .icon-cursor-left.slick-arrow {
        left: 15px !important;
        width: 30px !important;
        height: 30px !important;
    }

    .hero-slider .icon-cursor-left.slick-arrow::before {
        width: 22px !important;
        height: 22px !important;
        border-left: 3px solid #fff !important;
        border-bottom: 3px solid #fff !important;
    }

    .hero-slider .icon-cursor-right.slick-arrow {
        right: 15px !important;
        width: 30px !important;
        height: 30px !important;
    }

    .hero-slider .icon-cursor-right.slick-arrow::before {
        width: 22px !important;
        height: 22px !important;
        border-right: 3px solid #fff !important;
        border-top: 3px solid #fff !important;
    }

    #project-header .project-title-wrap {
        padding: 15px 0 15px 20px !important;
    }

    div#project-header::before {
        width: 20px !important;
    }

    .hero-slider ul.slick-dots button::after {
        transform: translate(-50%, -50%) scale(1);
        box-shadow: 0px 0px 3px 0px rgba(0, 0, 0, .1), 0px 0px 2px 1px rgb(0 0 0 / 10%) !important;
    }

    .hero-slider ul.slick-dots {
        bottom: 30% !important;
    }

    .hero-slider ul.slick-dots button {
        background: transparent !important;
        border: 2px solid #fff;
        width: 15px !important;
        height: 15px !important;
    }

    #content-wrapper .project-contact.mobile {
        padding: 10px 0 10px 0px;
    }
}


