.header-select-dropdown select {
    font-size: 18px;
    font-family: 'Oswald';
    text-transform: uppercase;
    background: #9F3238;
    color: #fff;
    border: 0;
    outline: 0;
    border-radius: 0;
    padding: 8px 28px 8px 8px;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    background-image: url(/assets-f/img/49049409785b3f.png);
    background-repeat: no-repeat;
    background-position: center right;
    height: auto;
    cursor: pointer;
    max-width: 150px;
    text-overflow: ellipsis;
    white-space: nowrap;
    background-size: 22px;
    line-height: 1;
}

.header-select-dropdown select:focus {
    border: 0;
}

